{
  "name": "ts-ag",
  "version": "1.0.5",
  "description": "Useful TS stuff",
  "bugs": "https://github.com/ageorgeh/ts-ag/issues",
  "author": "Alexander Hornung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ageorgeh/ts-ag.git"
  },
  "bin": {
    "check-llrt-worker": "dist/scripts/check-llrt-worker.mjs",
    "ts-alias": "dist/scripts/ts-alias.mjs",
    "ts-build-config": "dist/scripts/ts-build-config.mjs"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "worker": {
        "types": "./dist/worker.d.mts",
        "default": "./dist/worker.mjs"
      },
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "check:llrt-worker": "node ./dist/scripts/check-llrt-worker.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "test": "vitest --run",
    "tsc:check": "tsgo --noEmit",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@ungap/structured-clone": "1.3.1",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "cookie-es": "3.1.1",
    "cycle": "1.0.3",
    "dequal": "^2.0.3",
    "devalue": "^5.8.0",
    "get-tsconfig": "^4.14.0",
    "glob": "^13.0.6",
    "neverthrow": "8.2.0",
    "oxfmt": "^0.48.0",
    "radash": "^12.1.1",
    "rehype-parse": "9.0.1",
    "tsc-alias": "1.8.17",
    "type-fest": "^5.6.0",
    "unified": "11.0.5",
    "valibot": "1.4.0",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@actions/languageserver": "^0.3.55",
    "@aws-sdk/client-cognito-identity-provider": "3.1044.0",
    "@aws-sdk/client-s3": "3.1044.0",
    "@aws-sdk/s3-request-presigner": "3.1044.0",
    "@smithy/smithy-client": "4.12.13",
    "@types/aws-lambda": "8.10.161",
    "@types/hast": "3.0.4",
    "@types/node": "^24.12.2",
    "@types/ungap__structured-clone": "1.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "concurrently": "^9.2.1",
    "dynamodb-toolbox": "^2.8.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxlint": "^1.63.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@smithy/smithy-client": "^4",
    "@smithy/types": "^4",
    "@types/aws-lambda": "8.10.161",
    "dynamodb-toolbox": "^2",
    "typescript": "^5.0.0 || ^6.0.0"
  }
}
