{
  "name": "ts-ag",
  "version": "1.0.5",
  "description": "Useful TS stuff",
  "bugs": "https://github.com/ageorgeh/ts-ag/issues",
  "author": "Alexander Hornung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ageorgeh/ts-ag.git"
  },
  "bin": {
    "ts-alias": "dist/scripts/ts-alias.mjs",
    "ts-build-config": "dist/scripts/ts-build-config.mjs"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "test": "vitest --run",
    "tsc:check": "tsgo --noEmit",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "3.1014.0",
    "@aws-sdk/client-s3": "3.1014.0",
    "@aws-sdk/s3-request-presigner": "3.1014.0",
    "@ungap/structured-clone": "1.3.0",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "cookie": "1.1.1",
    "cycle": "1.0.3",
    "dequal": "^2.0.3",
    "devalue": "^5.6.4",
    "get-tsconfig": "^4.13.7",
    "glob": "^13.0.6",
    "jose": "6.2.2",
    "neverthrow": "8.2.0",
    "oxfmt": "^0.41.0",
    "radash": "^12.1.1",
    "rehype-parse": "9.0.1",
    "tsc-alias": "1.8.16",
    "type-fest": "^5.5.0",
    "unified": "11.0.5",
    "valibot": "1.3.1",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@actions/languageserver": "^0.3.49",
    "@types/aws-lambda": "8.10.161",
    "@types/hast": "3.0.4",
    "@types/node": "^24.12.0",
    "@types/ungap__structured-clone": "1.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "concurrently": "^9.2.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "typescript-svelte-plugin": "0.3.50",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@types/aws-lambda": "8.10.161",
    "typescript": "^5.0.0 || ^6.0.0"
  }
}
